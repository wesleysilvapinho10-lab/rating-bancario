# Supabase
# URL e chave anônima (pública) do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave de service role (SECRETA, nunca exponha no client) usada na API route para inserir leads
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# WhatsApp do especialista (formato internacional, somente números)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
